{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Bottke Clinical Design System — Brand Kit B (oxblood). Single source of truth for the Inpatient Antibiotic Guide. CSS custom-property names are the leaf keys verbatim (e.g. `ox-deep` -> `--ox-deep`); the build emits them all onto `:root`. Previously these values were duplicated inline on `.rx-root` and `.sx-root`; this file unifies them.",
  "color": {
    "$type": "color",
    "surface": {
      "paper":  { "$value": "#FBFAF8", "$description": "App background." },
      "paper2": { "$value": "#F5F2EC", "$description": "Inset / chip background." },
      "panel":  { "$value": "#FFFFFF", "$description": "Raised panel / card." }
    },
    "text": {
      "ink":   { "$value": "#1B1916", "$description": "Primary text." },
      "ink2":  { "$value": "#403B34", "$description": "Secondary text." },
      "muted": { "$value": "#6E675E", "$description": "Tertiary / captions (AA on paper)." },
      "faint": { "$value": "#9A9389", "$description": "Decorative / non-text glyphs only (sub-AA)." }
    },
    "rule": {
      "line":  { "$value": "#E6E0D8", "$description": "Default border." },
      "line2": { "$value": "#F1ECE5", "$description": "Subtle border." },
      "line3": { "$value": "#FAF7F2", "$description": "Faintest divider." }
    },
    "oxblood": {
      "ox":        { "$value": "#7A1B1E", "$description": "Primary accent." },
      "ox-deep":   { "$value": "#5E1416", "$description": "High-emphasis value text." },
      "ox-bright": { "$value": "#9B2D2F", "$description": "Hover / active." },
      "ox-soft":   { "$value": "#F7ECEA", "$description": "Tinted callout bg." },
      "ox-softer": { "$value": "#FCF6F5", "$description": "Faint accent wash." },
      "ox-line":   { "$value": "#E2C7C4", "$description": "Accent border." }
    },
    "amber": {
      "amber":      { "$value": "#8A5A12", "$description": "Caution accent." },
      "amber-soft": { "$value": "#FBF1DF", "$description": "Caution bg." },
      "amber-line": { "$value": "#EAD8B4", "$description": "Caution border." }
    },
    "red": {
      "$description": "Required / hard-stop severity. Wave 5 CL-1 — these were previously hardcoded inline (#b91c1c + rgba 185/28/28) across MonitoringBlock / DiagnosticsBlock / OPATBlock / RegimenOptions microbiome chips. Promoted to tokens so any future palette tweak ripples in one place and the severity grammar reads from the same source as everything else.",
      "red":      { "$value": "#B91C1C", "$description": "Required / hard-stop accent." },
      "red-soft": { "$value": "rgba(185, 28, 28, 0.08)", "$description": "Required bg tint." },
      "red-line": { "$value": "rgba(185, 28, 28, 0.25)", "$description": "Required border." }
    },
    "overlay": {
      "$description": "Modal scrim color. Wave 5 CL-1 — previously inline across MechanismDrawer + DecisionAttributionDrawer.",
      "scrim": { "$value": "rgba(15, 23, 42, 0.45)", "$description": "Backdrop scrim behind modal drawers." }
    },
    "green": {
      "green":      { "$value": "#2F5D3A", "$description": "Affirmative accent." },
      "green-soft": { "$value": "#EAF1EB", "$description": "Affirmative bg." },
      "green-line": { "$value": "#CADCCD", "$description": "Affirmative border." }
    },
    "blue": {
      "blue":      { "$value": "#2B4C66", "$description": "Informational accent." },
      "blue-soft": { "$value": "#E9EFF4", "$description": "Informational bg." },
      "blue-line": { "$value": "#C3D4E0", "$description": "Informational border." }
    },
    "star": {
      "star":      { "$value": "#B5862B", "$description": "Drug-of-choice marker." },
      "star-soft": { "$value": "#F7EFDC", "$description": "Drug-of-choice wash (spectrum)." }
    },
    "supergroup": {
      "$description": "Taxonomic supergroup tints for the spectrum matrix — pale, categorical, never the data channel.",
      "sg-gp":      { "$value": "#4C3A6B", "$description": "Gram-positive." },
      "sg-gp-bg":   { "$value": "#F1ECF5" },
      "sg-ent":     { "$value": "#1F5A5A", "$description": "Enterobacterales." },
      "sg-ent-bg":  { "$value": "#E7F1F0" },
      "sg-nf":      { "$value": "#8A4A12", "$description": "Non-fermenters." },
      "sg-nf-bg":   { "$value": "#FBEEDF" },
      "sg-fas":     { "$value": "#345B2B", "$description": "Fastidious / zoonotic." },
      "sg-fas-bg":  { "$value": "#ECF3E8" },
      "sg-ana":     { "$value": "#6A4A2A", "$description": "Anaerobes." },
      "sg-ana-bg":  { "$value": "#F3ECE2" },
      "sg-atyp":    { "$value": "#3A4A5C", "$description": "Atypicals." },
      "sg-atyp-bg": { "$value": "#EBEFF3" },
      "sg-spz":     { "$value": "#2E6E7E", "$description": "Spirochetes / intracellular." },
      "sg-spz-bg":  { "$value": "#E6F0F2" }
    },
    "decision": {
      "$description": "Semantic decision-channel tokens for the Bedside answer canvas. Each state is a triple (text · bg · border) for tags, chips, and dose rows that need to read as a clinical action at a glance. Values alias the existing palette so the decision channel stays inside the Brand Kit B grammar.",
      "decision-start":      { "$value": "#2F5D3A", "$description": "Start as written / on-label." },
      "decision-start-bg":   { "$value": "#EAF1EB", "$description": "Start bg." },
      "decision-start-line": { "$value": "#CADCCD", "$description": "Start border." },
      "decision-adjusted":      { "$value": "#8A5A12", "$description": "Adjusted from standard — renal, weight, or substitution." },
      "decision-adjusted-bg":   { "$value": "#FBF1DF", "$description": "Adjusted bg." },
      "decision-adjusted-line": { "$value": "#EAD8B4", "$description": "Adjusted border." },
      "decision-avoid":      { "$value": "#7A1B1E", "$description": "Avoid / contraindicated for this patient." },
      "decision-avoid-bg":   { "$value": "#F7ECEA", "$description": "Avoid bg." },
      "decision-avoid-line": { "$value": "#E2C7C4", "$description": "Avoid border." },
      "decision-pending":      { "$value": "#6E675E", "$description": "Awaiting data — culture pending, susceptibility unknown." },
      "decision-pending-bg":   { "$value": "#F1ECE5", "$description": "Pending bg." },
      "decision-pending-line": { "$value": "#E6E0D8", "$description": "Pending border." }
    }
  },
  "shadow": {
    "$description": "Elevation shadows. Wave 5 CL-1 — previously inline drawer shadow consolidated here.",
    "shadow-drawer": { "$value": "0 24px 48px -16px rgba(15, 23, 42, 0.35)", "$description": "Lifted-panel shadow under modal drawers." }
  },
  "font": {
    "$type": "fontFamily",
    "serif": { "$value": "'Lora', Georgia, 'Times New Roman', serif", "$description": "Display." },
    "sans":  { "$value": "'DM Sans', system-ui, -apple-system, sans-serif", "$description": "Body." },
    "mono":  { "$value": "'IBM Plex Mono', ui-monospace, 'SF Mono', monospace", "$description": "Numerals / labels." }
  }
}
