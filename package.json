{
  "name": "inpatient-abx-guide",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Inpatient Antibacterial Reference & Selection Engine — Vite + React + TS, token-driven, with integrity / render / a11y gates.",
  "scripts": {
    "tokens": "node scripts/build-tokens.mjs",
    "dev": "npm run tokens && vite",
    "build": "npm run tokens && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "content:audit": "vitest run tests/content-audit.test.js",
    "content:scaffold": "node scripts/new-syndrome.mjs",
    "verify": "npm run typecheck && npm run test && npm run build && npm run test:e2e"
  },
  "dependencies": {
    "lucide-react": "0.383.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.9"
  }
}
